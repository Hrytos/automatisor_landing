<div class="bg-grid" aria-hidden="true"></div>

<%- include('partials/header', { showProductLink: false, headerCtaText: 'Assess a Warehouse' }) %>

<main>

  <video class="main-bg-video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
    <source src="/images/herobgvideo.mp4" type="video/mp4">
  </video>
  <div class="main-bg-video-overlay" aria-hidden="true"></div>

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container hero-inner">
      <button type="button" class="badge-pill hero-badge-trigger" id="hero-badge-trigger" aria-haspopup="dialog">
            For<span class="sep">|</span><strong>Customer Success</strong>
      </button>
      <h1 class="hero-title">
        Which of your warehouse customers<br>
        <span class="text-accent">renew, expand or churn</span> this year?<br>
        Find out before your competitors do.
      </h1>
      <p class="hero-sub">
        We monitor signals across your customer warehouses to identify expansion opportunities, renewal risks and early signs of churn; before they show up in your pipeline or your competitor's.
      </p>
      <div class="hero-actions">
        <a href="/demo" class="btn btn-light btn-lg">Assess a Warehouse</a>
        <!-- <a href="#sample" class="btn btn-outline btn-lg">Talk to us</a> -->
      </div>
    </div>
  </section>

  <!-- ============ HAND US A MARKET PANEL ============ -->
  <section class="market-panel-wrap">
    <div class="container">
      <div class="market-panel">
        <div class="market-panel-head">
          <h2>The danger isn't that your customers are changing.<br>It's that your competitors notice & act before you do.</h2>
          <p>Conversations, Google, Linkedin, Maps, Glassdoor, Indeed, Publications, Company website, Case Studies, Blogs, Local News, Financial Reports, Images, Regulatory Filings, Employee Reviews.... <br><br> 47 open tabs, hours gone into research, still unsure if this warehouse will renew or churn this year! <br>Sounds familiar? </p>
        </div>

        <div class="market-panel-dark">

          <div class="step-row-head">
            <h2 class="step-row-eyebrow">How Automatisor works</h2>
          </div>
          <div class="step-row">
            <div class="step-card">
              <span class="step-num">1</span>
              <p>Add your warehouse customers.</p>
            </div>
            <div class="step-card">
              <span class="step-num">2</span>
              <p>We continuously monitor signals across your customer warehouses & alert you to key changes</p>
            </div>
            <div class="step-card">
              <span class="step-num">3</span>
              <p>You get risk assessment for each warehouse and actionable recommendations to mitigate them.</p>
            </div>
          </div>

          <div class="market-visual-row">
            <div class="chat-demo">
              <div class="chat-demo-numbers" id="chat-demo-numbers" aria-label="Conversation examples"></div>
              <div class="chat-thread" id="chat-thread" data-persona="customer-success" aria-live="polite"></div>
            </div>

            <div class="market-sample">
              <h3>Try for Free</h3>
              <p>Which warehouse you definitely don't want to lose?<br><br> We identify expansion opportunities, renewal risks and early signs of churn. We also prepare you for conversations.</p>
              <a href="/demo" class="btn btn-dark btn-lg">Assess a Warehouse</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

