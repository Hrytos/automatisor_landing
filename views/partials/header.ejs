<!-- ============ HEADER ============ -->
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <img src="/images/logo_light.png" alt="automatisor" class="brand-logo">
    </a>
    <nav class="main-nav">
      <div class="nav-hover-item">
        <a href="/" class="nav-hover-trigger">For Customer Success</a>
        <a href="/" class="nav-hover-panel">
          <span class="nav-dropdown-item-field">
            <span class="nav-dropdown-item-label">For whom?</span>
            <span class="nav-dropdown-item-value">Customer Success, Account Management & Revenue teams</span>
          </span>
          <span class="nav-dropdown-item-field">
            <span class="nav-dropdown-item-label">Benefit</span>
            <span class="nav-dropdown-item-value">Identify warehouses with expansion opportunity, renewal risks & churn signs.</span>
          </span>
        </a>
      </div>
      <div class="nav-hover-item">
        <a href="/sales" class="nav-hover-trigger">For Customer Acquisition</a>
        <a href="/sales" class="nav-hover-panel">
          <span class="nav-dropdown-item-field">
            <span class="nav-dropdown-item-label">For whom?</span>
            <span class="nav-dropdown-item-value">Sales, Business Development & Marketing teams</span>
          </span>
          <span class="nav-dropdown-item-field">
            <span class="nav-dropdown-item-label">Benefit</span>
            <span class="nav-dropdown-item-value">Identify warehouses worth pursuing, uncover why they are a strong automation candidates & prospect with confidence.</span>
          </span>
        </a>
      </div>
      <% if (typeof showProductLink !== 'undefined' && showProductLink) { %>
      <a href="#product">Product</a>
      <% } else { %>
      <!-- <a href="#product">Product</a> -->
      <% } %>
    </nav>
    <% if (typeof showHeaderActions === 'undefined' || showHeaderActions) { %>
    <div class="header-actions">
      <a href="https://app.automatisor.com/auth" class="btn btn-ghost btn-sm header-login">Log in</a>
      <a href="/demo" class="btn btn-light btn-sm header-cta"><%= headerCtaText %></a>
      <button type="button" class="mobile-menu-trigger" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 5h14M2 9h14M2 13h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <% } %>
  </div>
  <% if (typeof showHeaderActions === 'undefined' || showHeaderActions) { %>
  <div class="mobile-nav" id="mobile-nav" hidden>
    <a href="/demo" class="btn btn-light mobile-nav-cta"><%= headerCtaText %></a>
    <a href="/" class="mobile-nav-link">
      <span class="mobile-nav-link-title">For Customer Success</span>
      <span class="mobile-nav-link-sub">Customer Success, Account Management & Revenue teams</span>
    </a>
    <a href="/sales" class="mobile-nav-link">
      <span class="mobile-nav-link-title">For Customer Acquisition</span>
      <span class="mobile-nav-link-sub">Sales, Business Development & Marketing teams</span>
    </a>
    <% if (typeof showProductLink !== 'undefined' && showProductLink) { %>
    <a href="#product" class="mobile-nav-link">
      <span class="mobile-nav-link-title">Product</span>
    </a>
    <% } %>
    <a href="https://app.automatisor.com/auth" class="mobile-nav-link">
      <span class="mobile-nav-link-title">Log in</span>
    </a>
  </div>
  <% } %>
</header>
